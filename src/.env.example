# Vercel Blob Storage Token (will be generated by vercel CLI)
BLOB_READ_WRITE_TOKEN=

# NextAuth
# Generate a random secret (e.g. `openssl rand -base64 32`) for production
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional: Admin password (defaults to 'admin123' if not set)
ADMIN_PASSWORD=admin123

# Optional: Blob base URL (auto-generated by Vercel)
BLOB_BASE_URL=
