generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id             String             @id @default(cuid())
  username       String             @unique
  passwordHash   String
  displayName    String
  role           String             @default("viewer") // viewer | editor | approver | admin
  accessScope    String             @default("national") // national | kanwil | cabang
  kanwil         String?
  cabang         String?
  isActive           Boolean            @default(true)
  mustChangePassword Boolean            @default(false)
  totpSecret         String?
  totpEnabled        Boolean            @default(false)
  totpLastVerifiedAt DateTime?
  createdAt          DateTime           @default(now())
  totpAttempts   TotpAttempt[]
  auditLogs      SecurityAuditLog[] @relation("AuditLogSubject")
  actedAuditLogs SecurityAuditLog[] @relation("AuditLogActor")
}

model TotpAttempt {
  id        Int      @id @default(autoincrement())
  userId    String
  context   String
  success   Boolean
  ip        String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, context, createdAt])
}

model SecurityAuditLog {
  id          Int      @id @default(autoincrement())
  userId      String
  actorUserId String?
  action      String
  dataType    String?
  ip          String
  userAgent   String   @db.NVarChar(Max)
  createdAt   DateTime @default(now())
  user        User     @relation("AuditLogSubject", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([dataType, createdAt])
}

model Memo {
  id            String    @id @default(cuid())
  nomorMemo     String    @default("") // e.g. 0042/M/BBD/CPD/III/2026 — filled manually or left blank in draft
  category      String    @default("general") // general | izin_prinsip
  perihal       String    @default("")
  kepada        String    @default("[]") @db.NVarChar(Max) // JSON: [{ division: string, department?: string }]
  dari          String    @default("")   // e.g. "Business Banking Division (BBD)"
  tanggalMemo   DateTime  @default(now())
  konten        String    @default("") @db.NVarChar(Max) // rich text HTML from Tiptap
  lampiranList  String    @default("[]") @db.NVarChar(Max) // JSON: string[] — numbered lampiran items in document
  tembusan      String    @default("[]") @db.NVarChar(Max) // JSON: string[] — CC list
  metadata      String    @default("{}") @db.NVarChar(Max) // JSON: category-specific fields
  // izin_prinsip metadata keys:
  // namaDebitur, jenisIzinPrinsip, jenisKredit, plafond, jangkaWaktu,
  // nomorMemoKC, nomorMemoResponse, keputusan, kanwil, cabang
  status        String    @default("draft") // draft | review | approved | distributed
  createdBy     String    @default("") // User.username
  reviewedBy    String?
  approvedBy    String?
  distributedBy String?
  distributedTo String    @default("[]") @db.NVarChar(Max) // JSON: kanwil codes
  attachments   String    @default("[]") @db.NVarChar(Max) // JSON: storage keys for uploaded files
  notes         String?   @db.NVarChar(Max)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewedAt    DateTime?
  approvedAt    DateTime?
  distributedAt DateTime?

  // --- Tracking sirkulasi (pipeline PIC → Kadept → Sekretaris → Kadiv → PIC → Arsip) ---
  trackingStep        Int       @default(0)    // index tahap aktif (>= jumlah tahap berarti selesai)
  stepHistory         String    @default("[]") @db.NVarChar(Max) // JSON: [{ step: int, date: ISO, note: string, by: string }]
  slaHours            Int       @default(8)    // batas SLA per tahap (jam)
  trackingRoles       String    @default("{}") @db.NVarChar(Max) // JSON: { pic, kadept, sekretaris, kadiv }
  trackingStartedAt   DateTime?                // null = tracking belum dimulai
  trackingCompletedAt DateTime?
}
