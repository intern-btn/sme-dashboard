# Storage
# Production on Netlify: STORAGE_PROVIDER=netlify-blob.
# Local/self-hosted: STORAGE_PROVIDER=local and optionally DATA_DIR=./data.
STORAGE_PROVIDER=local
# DATA_DIR=./data

# One-off Vercel Blob -> Netlify Blobs migration only.
# BLOB_READ_WRITE_TOKEN=
# NETLIFY_SITE_ID=
# NETLIFY_AUTH_TOKEN=
# NETLIFY_BLOBS_STORE=sme-dashboard-storage

# Database
# Local dev: DATABASE_URL=file:./dev.db (no TURSO_AUTH_TOKEN needed)
# Production: DATABASE_URL=libsql://[db-name].turso.io, TURSO_AUTH_TOKEN=your-token
DATABASE_URL=file:./dev.db
TURSO_AUTH_TOKEN=

# Seeding (Prisma seed uses this to set the initial admin user's password)
ADMIN_PASSWORD=admin123

# NextAuth (required)
# Generate a random secret for production (example: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# TOTP 2FA and confidential data unlock
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
TOTP_UNLOCK_SECRET=
