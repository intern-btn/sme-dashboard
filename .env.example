# Storage
# Use Vercel Blob in Vercel deployments. For fully local/self-hosted, set STORAGE_PROVIDER=local.
BLOB_READ_WRITE_TOKEN=
BLOB_BASE_URL=
STORAGE_PROVIDER=local
DATA_DIR=./data

# File upload transport: 'true' uses Vercel Blob client (required on Vercel; bypasses 4.5MB body limit),
# 'false' sends files as FormData (local dev only — no Vercel Blob token needed)
NEXT_PUBLIC_USE_DIRECT_UPLOAD=false

# Database — SQL Server
# For the Docker app (connects to the 'db' service inside Docker network):
#   DATABASE_URL="sqlserver://db:1433;database=sme_dashboard;user=sa;password=YOUR_SA_PASSWORD;trustServerCertificate=true"
# For running migrations locally (before or outside of Docker):
#   DATABASE_URL="sqlserver://localhost:1433;database=sme_dashboard;user=sa;password=YOUR_SA_PASSWORD;trustServerCertificate=true"
DATABASE_URL="sqlserver://db:1433;database=sme_dashboard;user=sa;password=YOUR_SA_PASSWORD;trustServerCertificate=true"

# SQL Server SA password — must match the password in DATABASE_URL above
# Also used by docker-compose to set the SA password on the db container
DB_SA_PASSWORD=YOUR_SA_PASSWORD

# Seeding (Prisma seed uses this to set the initial admin user's password)
ADMIN_PASSWORD=admin123

# NextAuth (required)
# Generate a random secret for production (example: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# TOTP 2FA and confidential data unlock
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
TOTP_UNLOCK_SECRET=
