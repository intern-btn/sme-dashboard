# Storage
# Use Vercel Blob in Vercel deployments. For fully local/self-hosted, set STORAGE_PROVIDER=local.
BLOB_READ_WRITE_TOKEN=
BLOB_BASE_URL=
STORAGE_PROVIDER=vercel-blob
# DATA_DIR=./data

# Upload
NEXT_PUBLIC_USE_DIRECT_UPLOAD=true

# Database
DATABASE_URL=file:./dev.db

# Seeding (Prisma seed uses this to set the initial admin user's password)
ADMIN_PASSWORD=admin123

# NextAuth (required)
# Generate a random secret for production (example: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

