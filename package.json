{
  "name": "sme-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "node --experimental-vm-modules prisma/seed.js",
    "db:seed:memos": "node --experimental-vm-modules prisma/seed-memos.js",
    "db:migrate": "node scripts/apply-turso-migrations.mjs",
    "db:migrate:baseline": "node scripts/apply-turso-migrations.mjs --baseline-existing",
    "db:migrate:dry": "node scripts/apply-turso-migrations.mjs --dry-run",
    "db:setup": "npm run db:migrate && prisma generate && npm run db:seed:memos",
    "db:setup:baseline": "npm run db:migrate:baseline && prisma generate && npm run db:seed:memos"
  },
  "prisma": {
    "seed": "node --experimental-vm-modules prisma/seed.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@netlify/blobs": "^10.7.9",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tiptap/extension-table": "^3.21.0",
    "@tiptap/extension-table-cell": "^3.21.0",
    "@tiptap/extension-table-header": "^3.21.0",
    "@tiptap/extension-table-row": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "otplib": "^13.4.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "turso": "^0.6.0-pre.21",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@vercel/blob": "^2.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "react-grab": "^0.1.32",
    "tailwindcss": "^3.4.0"
  }
}
